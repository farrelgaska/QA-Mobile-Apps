# Local file-backed development (default)
DATA_PROVIDER=json
PORT=3002
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# PostgreSQL mode through the Supabase transaction pooler. Placeholders only.
DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
DATABASE_POOL_MAX=2
DATABASE_SSL=true
DATABASE_SSL_REJECT_UNAUTHORIZED=true

# Reserved for future object/file storage; not used by data repositories.
# STORAGE_PROVIDER=supabase
